# outline-64 — pefchain script (Spindle 3.1 high-level framework)
#
# Pefchain links the .pef effects below in sequence, background-loading
# each upcoming part during the current one (via the NMI-driven loader).
#
# Transitions: each part auto-advances on a timer / state condition.
# No space-key required — the demo plays straight through to the end
# card, which loops forever ("stay").
#
#   06 = 00   wait until zp $06 == 0  (screenfill: HOLDCNT drained ~3s)
#   f6 = f0   wait until zp $f6 == $f0 (intro: zp_outro hit T_OUTRO_DONE)
#   f6 = 20   wait until zp $f6 == $20 (interlude: 32 beats ≈ 15 sec —
#                                       same byte, repurposed by
#                                       interlude's setup which resets it)
#   f6 = 20   wait until zp $f6 == $20 (greets: same trick — greets'
#                                       setup resets f6 to 0, then
#                                       ticks back up to $20 over ~15 s)
#   f6 = 30   wait until zp $f6 == $30 (sinus: frame counter stalls at
#                                       $30+ after ~5 s, catches $30
#                                       on the way past)
#   stay      never advance (end card loops forever)

parts/screenfill/screenfill.pef     06 = 00
parts/intro/intro.pef               f6 = f0
parts/interlude/interlude.pef       f6 = 20
parts/greets/greets.pef             f6 = 20
parts/sinus/sinus.pef               f6 = 30
parts/end/end.pef                   stay
