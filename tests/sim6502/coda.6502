; sim6502 unit tests for coda pure routines.   ./tests/sim6502/run.sh
;
; kloot_advance — ping-pong shape counter for one Kloot star, X-indexed
; (X = star: 0 or 1). Forward (dir==0): inc shape; at KLOOT_FRAMES_TOTAL(24)
; clamp to 23 and flip dir to backward ($ff). Backward (dir!=0): dec shape;
; under 0 ($ff) clamp to 0 and flip dir to forward (0). Pure: depends only
; on X + kloot_shape[X] / kloot_dir[X].
;   star 0: shape=[kloot_shape_1]($c0f) dir=[kloot_dir_1]($c11)
;   star 1: shape=[kloot_shape_2]($c10) dir=[kloot_dir_2]($c12)

suites {
  suite("coda: kloot_advance — ping-pong star-shape counter") {
    symbols("/code/tests/sim6502/coda.sym")
    load("/code/tests/sim6502/coda.prg", strip_header = true)

    test("ka-forward-step", "forward mid-range just increments") {
      x = $00
      [kloot_dir_1]   = $00      ; forward
      [kloot_shape_1] = $05
      jsr([kloot_advance], stop_on_rts = true, fail_on_brk = true)
      assert([kloot_shape_1] == $06, "shape 5 -> 6")
      assert([kloot_dir_1]   == $00, "still forward")
    }

    test("ka-forward-flip-at-top", "clamps at 23 and flips to backward") {
      x = $00
      [kloot_dir_1]   = $00      ; forward
      [kloot_shape_1] = $17      ; 23 (KLOOT_FRAME_LAST)
      jsr([kloot_advance], stop_on_rts = true, fail_on_brk = true)
      assert([kloot_shape_1] == $17, "stays clamped at 23")
      assert([kloot_dir_1]   == $ff, "direction flipped to backward")
    }

    test("ka-backward-step", "backward mid-range just decrements") {
      x = $00
      [kloot_dir_1]   = $ff      ; backward
      [kloot_shape_1] = $0a      ; 10
      jsr([kloot_advance], stop_on_rts = true, fail_on_brk = true)
      assert([kloot_shape_1] == $09, "shape 10 -> 9")
      assert([kloot_dir_1]   == $ff, "still backward")
    }

    test("ka-backward-flip-at-bottom", "clamps at 0 and flips to forward") {
      x = $00
      [kloot_dir_1]   = $ff      ; backward
      [kloot_shape_1] = $00
      jsr([kloot_advance], stop_on_rts = true, fail_on_brk = true)
      assert([kloot_shape_1] == $00, "stays clamped at 0")
      assert([kloot_dir_1]   == $00, "direction flipped to forward")
    }

    test("ka-star2-independent", "X=1 advances star 2 without touching star 1") {
      x = $01
      [kloot_dir_2]   = $00
      [kloot_shape_2] = $03
      [kloot_shape_1] = $aa      ; sentinel on the OTHER star
      jsr([kloot_advance], stop_on_rts = true, fail_on_brk = true)
      assert([kloot_shape_2] == $04, "star 2 advanced 3 -> 4")
      assert([kloot_shape_1] == $aa, "star 1 untouched (X-indexed)")
    }
  }

  ; --------------------------------------------------------------------
  ; star_field — the parallax star tick. Gated: the body runs ONLY when
  ; zp_subtick ($fb, a .const so not in the .sym -> raw addr) == 0; else
  ; immediate RTS. When it runs it sweeps X = 31..0: dec star_tick[X], and
  ; only when that hits 0 does star X MOVE one column left:
  ;   reload star_tick[X] = tier_speed[tier]; erase old cell to $20; col -=1
  ;   (wrap $ff -> $27); draw tier_char[tier] at new col; tier_color[tier]
  ;   into colour RAM at the new col.  tier_speed={3,5,8,14}
  ;   tier_char={$51,$57,$5a,$2e} (PETSCII ● ○ ◆ ·)  tier_color={$01,$03,$0e,$06}.
  ; Per-star arrays are referenced by SYMBOL ([star_tick]/[star_col]/
  ; [star_row]/[star_tier]) so the suite survives coda layout shifts. To
  ; force a single deterministic move we memfill all 32 ticks to $ff
  ; (dec -> $fe, never moves) and arm only star 0 (processed last in the
  ; X=31..0 sweep).
  ; Pure RAM: $0400/$d800 are plain RAM in the sim, no $d012/keyboard/CIA.
  ; --------------------------------------------------------------------
  suite("coda: star_field — gated parallax star tick") {
    symbols("/code/tests/sim6502/coda.sym")
    load("/code/tests/sim6502/coda.prg", strip_header = true)

    test("sf-gated-skip", "zp_subtick != 0 -> immediate RTS, nothing touched") {
      $fb = $01             ; gate closed
      [star_tick] = $01     ; star 0 tick would otherwise hit 0 and move
      [star_row]  = $00     ; row 0
      [star_col]  = $0a     ; col 10
      [star_tier] = $00     ; tier 0
      $0409 = $aa           ; sentinels on cells a move WOULD touch
      $d809 = $aa
      jsr([star_field], stop_on_rts = true, fail_on_brk = true)
      assert([star_tick] == $01, "tick NOT decremented (early RTS)")
      assert($0409 == $aa, "screen untouched (gate closed)")
      assert($d809 == $aa, "colour RAM untouched (gate closed)")
    }

    test("sf-single-move-tier0", "one star moves left, draws ● / white at new col") {
      $fb = $00                      ; gate open
      memfill([star_tick], 32, $ff)  ; freeze all 32 ticks high (dec -> $fe, no move)
      [star_tick] = $01              ; arm star 0 (tick -> 0 -> MOVE)
      [star_row]  = $00              ; row 0
      [star_col]  = $0a              ; col 10
      [star_tier] = $00              ; tier 0
      $0409 = $aa                    ; sentinels at new-char + colour cells
      $d809 = $aa
      jsr([star_field], stop_on_rts = true, fail_on_brk = true)
      assert($040a == $20, "old col 10 erased to space")                              ; $0400+10
      assert($0409 == peekbyte([tier_char]),  "new col 9 = tier_char[0] = ● ($51)")   ; $0400+9
      assert($d809 == peekbyte([tier_color]), "colour col 9 = tier_color[0] = $01")   ; $d800+9
      assert([star_col] == $09, "col decremented 10 -> 9")
      assert([star_tick] == peekbyte([tier_speed]), "tick reloaded = tier_speed[0] = 3")
    }

    test("sf-col-wrap-tier3", "col 0 wraps to 39, draws · / blue at far right") {
      $fb = $00
      memfill([star_tick], 32, $ff)
      [star_tick] = $01          ; arm star 0 -> MOVE
      [star_row]  = $05          ; row 5  -> base $0400+5*40 = $04c8
      [star_col]  = $00          ; col 0  -> will wrap
      [star_tier] = $03          ; tier 3 (· / blue / speed 14)
      $04ef = $aa                ; sentinel at wrapped new-char cell ($04c8+39)
      $d8ef = $aa
      jsr([star_field], stop_on_rts = true, fail_on_brk = true)
      assert($04c8 == $20, "old col 0 erased to space")
      assert([star_col] == $27, "col wrapped 0 -> 39 ($27)")
      assert($04ef == peekbyte([tier_char] + 3),  "new col 39 = tier_char[3] = · ($2e)")
      assert($d8ef == peekbyte([tier_color] + 3), "colour col 39 = tier_color[3] = $06")
      assert([star_tick] == peekbyte([tier_speed] + 3), "tick reloaded = tier_speed[3] = 14")
    }

    test("sf-no-move-no-bleed", "tick>1 just decrements, leaves screen+colour alone") {
      $fb = $00
      memfill([star_tick], 32, $ff)
      [star_tick] = $02          ; star 0 tick = 2 -> dec to 1, NO move
      [star_row]  = $01          ; row 1
      [star_col]  = $14          ; col 20
      [star_tier] = $01          ; tier 1
      $043b = $aa                ; sentinels where a move would have written
      $d83b = $aa
      jsr([star_field], stop_on_rts = true, fail_on_brk = true)
      assert([star_tick] == $01, "tick decremented 2 -> 1 (no move)")
      assert([star_col] == $14, "col unchanged (no move)")
      assert($043b == $aa, "screen untouched (no move)")
      assert($d83b == $aa, "colour RAM untouched (no move)")
    }
  }

  ; --------------------------------------------------------------------
  ; sparkle_stars — the kick-synced star flash. No-op when spark_env == 0
  ; (immediate RTS). Otherwise: dec spark_env, then sweep X = 31..0 writing
  ; ONE colour-RAM cell per star at ($0400+row*40 + $d400) + col:
  ;   spark_env still != 0 after the dec -> sparkle_ramp[spark_env] (bright);
  ;   spark_env hit 0          -> tier_color[star_tier] (restore depth tint).
  ; sparkle_ramp = {$00,$0d,$0f,$01,$01,$0f} (idx 0 unused — restore path).
  ; Star 0 is processed LAST, so we park the other 31 at row 0/col 0 (their
  ; writes pile harmlessly on $d800) and assert star 0's unique cell.
  ; --------------------------------------------------------------------
  suite("coda: sparkle_stars — kick-synced star flash") {
    symbols("/code/tests/sim6502/coda.sym")
    load("/code/tests/sim6502/coda.prg", strip_header = true)

    test("sp-noop-when-zero", "spark_env == 0 -> immediate RTS, nothing touched") {
      [spark_env] = $00
      $d82d = $aa                ; sentinel where a flash WOULD write (row1,col5)
      jsr([sparkle_stars], stop_on_rts = true, fail_on_brk = true)
      assert([spark_env] == $00, "envelope untouched (early RTS)")
      assert($d82d == $aa, "colour RAM untouched (no-op)")
    }

    test("sp-bright-flash", "mid-envelope writes sparkle_ramp[env] into colour RAM") {
      memfill([star_row], 32, $00)   ; park all 32 stars at row 0
      memfill([star_col], 32, $00)   ; ...col 0 (writes pile on $d800)
      [spark_env] = $02              ; dec -> 1 (still bright)
      [star_row]  = $01              ; star 0 -> row 1
      [star_col]  = $05              ; star 0 -> col 5  ($d800+40+5 = $d82d)
      jsr([sparkle_stars], stop_on_rts = true, fail_on_brk = true)
      assert([spark_env] == $01, "envelope decremented 2 -> 1")
      assert($d82d == peekbyte([sparkle_ramp] + 1), "star 0 cell = sparkle_ramp[1] = $0d")
    }

    test("sp-restore-tier", "envelope hits 0 -> restores tier_color[tier]") {
      memfill([star_row], 32, $00)
      memfill([star_col], 32, $00)
      memfill([star_tier], 32, $00)  ; others restore tier 0 onto $d800
      [spark_env] = $01              ; dec -> 0 (restore path)
      [star_row]  = $01              ; star 0 -> row 1
      [star_col]  = $05              ; star 0 -> col 5  ($d82d)
      [star_tier] = $02              ; star 0 -> tier 2 (lt blue $0e)
      jsr([sparkle_stars], stop_on_rts = true, fail_on_brk = true)
      assert([spark_env] == $00, "envelope decremented 1 -> 0")
      assert($d82d == peekbyte([tier_color] + 2), "star 0 cell = tier_color[2] = $0e")
    }
  }
}
