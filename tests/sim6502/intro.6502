; sim6502 unit tests for intro pure routines.
; Run:  docker run -v ${PWD}:/code ghcr.io/barryw/sim6502:latest -s /code/tests/sim6502/intro.s6502
; (or:  ./tests/sim6502/run.sh)
;
; calc_active_count computes how many ball/X-logo sprites should be visible
; from the intro/outro tick counters — pure ZP math, no raster polling, so it
; runs on the fast flat-RAM `sim` backend. Contract (intro.asm:1114):
;   zp_intro   = $f8   (input)   T_BALLS       = 40 ($28)
;   zp_outro   = $f6   (input)   T_OUTRO_BALLS = 176 ($b0)
;   zp_active_count = $f5 (output) = max(0, intro_count - outro_count)
;     intro_count = 0            if zp_intro < T_BALLS
;                 = min(8, ((zp_intro-T_BALLS)>>3)+1) otherwise
;     outro_count = 0            if zp_outro == 0 or < T_OUTRO_BALLS
;                 = min(8, ((zp_outro-T_OUTRO_BALLS)>>3)+1) otherwise
; The .prg loads at $0810 so it leaves zero-page (our inputs) untouched.

suites {
  suite("intro: calc_active_count — ball spawn/despawn cascade") {
    symbols("/code/tests/sim6502/intro.sym")
    load("/code/tests/sim6502/intro.prg", strip_header = true)

    test("cac-before-spawn", "no sprites before T_BALLS") {
      $f8 = $00          ; zp_intro = 0
      $f6 = $00          ; zp_outro = 0
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $00, "0 active when intro tick is 0")
    }

    test("cac-just-below-threshold", "still 0 one tick before T_BALLS") {
      $f8 = $27          ; zp_intro = 39 (T_BALLS-1)
      $f6 = $00
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $00, "0 active at intro=39")
    }

    test("cac-first-sprite", "first sprite spawns exactly at T_BALLS") {
      $f8 = $28          ; zp_intro = 40 (T_BALLS)
      $f6 = $00
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $01, "1 active at T_BALLS")
    }

    test("cac-second-sprite", "second sprite 8 ticks later") {
      $f8 = $30          ; zp_intro = 48 (T_BALLS+8)
      $f6 = $00
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $02, "2 active at T_BALLS+8")
    }

    test("cac-all-eight", "all 8 spawned by T_BALLS+56") {
      $f8 = $60          ; zp_intro = 96 (T_BALLS+56)
      $f6 = $00
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $08, "8 active at T_BALLS+56")
    }

    test("cac-saturates", "count saturates at 8, never overflows") {
      $f8 = $ff          ; zp_intro = 255 (way past)
      $f6 = $00
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $08, "still 8 at intro=255 (saturated)")
    }

    test("cac-outro-despawns-one", "outro removes the first sprite") {
      $f8 = $ff          ; intro saturated (8 spawned)
      $f6 = $b0          ; zp_outro = 176 (T_OUTRO_BALLS) -> 1 despawned
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $07, "7 active after 1 despawn")
    }

    test("cac-outro-despawns-some", "outro removes two sprites at +8") {
      $f8 = $ff
      $f6 = $b8          ; zp_outro = 184 (T_OUTRO_BALLS+8) -> 2 despawned
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $06, "6 active after 2 despawns")
    }

    test("cac-outro-clears-all", "outro never drives the count negative") {
      $f8 = $ff
      $f6 = $ff          ; zp_outro = 255 -> 8+ despawned, clamps at 0
      jsr([calc_active_count], stop_on_rts = true, fail_on_brk = true)
      assert($f5 == $00, "0 active, no underflow")
    }
  }

  ; ----------------------------------------------------------------------
  ; reveal_column — the logo wipe-in. Called every frame; with zp_outro=0
  ; it reveals ONE cell column of bitmap rows 8-16: column = zp_intro -
  ; T_LOGO (200). Writes $67 to the 9 screen-RAM rows and $01 to the 9
  ; colour-RAM rows at that column. No write before T_LOGO or after 40
  ; columns. With zp_outro != 0 it branches to wipe_out_column.
  ;   screen rows 8..16: $0540 $0568 $0590 $05b8 $05e0 $0608 $0630 $0658 $0680
  ;   colour rows 8..16: $d940 $d968 $d990 $d9b8 $d9e0 $da08 $da30 $da58 $da80
  ;   inputs: zp_intro=$f8, zp_outro=$f6.  T_LOGO=200($c8).
  ; ----------------------------------------------------------------------
  suite("intro: reveal_column — logo wipe-in (left to right)") {
    symbols("/code/tests/sim6502/intro.sym")
    load("/code/tests/sim6502/intro.prg", strip_header = true)

    test("rc-before-T_LOGO", "no reveal one tick before T_LOGO") {
      $f8 = $c7          ; zp_intro = 199 (T_LOGO-1)
      $f6 = $00
      $0540 = $aa        ; sentinel in column 0
      $d940 = $aa
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0540 == $aa, "screen col0 untouched before T_LOGO")
      assert($d940 == $aa, "colour col0 untouched before T_LOGO")
    }

    test("rc-first-column", "column 0 revealed exactly at T_LOGO, all 9 rows") {
      $f8 = $c8          ; zp_intro = 200 (T_LOGO) -> column 0
      $f6 = $00
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0540 == $67, "row 8  col0 screen = $67")
      assert($05e0 == $67, "row 12 col0 screen = $67")
      assert($0680 == $67, "row 16 col0 screen = $67")
      assert($d940 == $01, "row 8  col0 colour = $01")
      assert($da80 == $01, "row 16 col0 colour = $01")
    }

    test("rc-mid-column", "column 10 at T_LOGO+10") {
      $f8 = $d2          ; zp_intro = 210 -> column 10
      $f6 = $00
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($054a == $67, "row 8  col10 screen = $67")
      assert($068a == $67, "row 16 col10 screen = $67")
      assert($d94a == $01, "row 8  col10 colour = $01")
    }

    test("rc-last-column", "column 39 at T_LOGO+39 (last)") {
      $f8 = $ef          ; zp_intro = 239 -> column 39
      $f6 = $00
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0567 == $67, "row 8  col39 screen = $67")
      assert($06a7 == $67, "row 16 col39 screen = $67")
    }

    test("rc-only-one-column", "reveals exactly one column, no bleed") {
      $f8 = $cd          ; zp_intro = 205 -> column 5
      $f6 = $00
      $0546 = $aa        ; sentinel in the NEXT column (6)
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0545 == $67, "column 5 written")
      assert($0546 == $aa, "column 6 left untouched (no bleed)")
    }

    test("rc-past-end", "no write after 40 columns") {
      $f8 = $f0          ; zp_intro = 240 -> column 40 (>= 40, complete)
      $f6 = $00
      $0540 = $aa
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0540 == $aa, "no reveal once wipe is complete")
    }

    test("rc-outro-branches-to-wipe", "zp_outro != 0 routes to wipe_out_column") {
      $f8 = $d2          ; zp_intro = 210 (would reveal col 10 if not outro)
      $f6 = $2d          ; zp_outro = 45 -> wipe offset 5 -> column 34
      $0562 = $aa        ; column 34 sentinel
      jsr([reveal_column], stop_on_rts = true, fail_on_brk = true)
      assert($0562 == $00, "branched to wipe: column 34 cleared")
    }
  }

  ; ----------------------------------------------------------------------
  ; wipe_out_column — outro mirror. column = 39 - (zp_outro - T_OUTRO_LOGO),
  ; so it walks 39 -> 0 (right to left) as zp_outro goes 40..79, clearing
  ; the 9 screen + 9 colour cells to $00. No write before T_OUTRO_LOGO(40)
  ; or after 40 columns. Uses zp_tmp($f9) as scratch.
  ; ----------------------------------------------------------------------
  suite("intro: wipe_out_column — logo wipe-out (right to left)") {
    symbols("/code/tests/sim6502/intro.sym")
    load("/code/tests/sim6502/intro.prg", strip_header = true)

    test("wc-before-T_OUTRO_LOGO", "no wipe one tick before T_OUTRO_LOGO") {
      $f6 = $27          ; zp_outro = 39 (T_OUTRO_LOGO-1)
      $0567 = $aa        ; column 39 sentinel
      jsr([wipe_out_column], stop_on_rts = true, fail_on_brk = true)
      assert($0567 == $aa, "untouched before T_OUTRO_LOGO")
    }

    test("wc-first-clears-col39", "column 39 cleared first, at T_OUTRO_LOGO") {
      $f6 = $28          ; zp_outro = 40 -> offset 0 -> column 39
      $0567 = $aa        ; row 8  col39
      $06a7 = $aa        ; row 16 col39
      jsr([wipe_out_column], stop_on_rts = true, fail_on_brk = true)
      assert($0567 == $00, "row 8  col39 cleared")
      assert($06a7 == $00, "row 16 col39 cleared")
    }

    test("wc-walks-right-to-left", "column 29 at T_OUTRO_LOGO+10") {
      $f6 = $32          ; zp_outro = 50 -> offset 10 -> column 29
      $055d = $aa        ; row 8 col29
      jsr([wipe_out_column], stop_on_rts = true, fail_on_brk = true)
      assert($055d == $00, "column 29 cleared (39-10)")
    }

    test("wc-last-clears-col0", "column 0 cleared last, at T_OUTRO_LOGO+39") {
      $f6 = $4f          ; zp_outro = 79 -> offset 39 -> column 0
      $0540 = $aa
      jsr([wipe_out_column], stop_on_rts = true, fail_on_brk = true)
      assert($0540 == $00, "column 0 cleared")
    }

    test("wc-past-end", "no write after 40 columns wiped") {
      $f6 = $50          ; zp_outro = 80 -> offset 40 (>= 40, complete)
      $0540 = $aa
      jsr([wipe_out_column], stop_on_rts = true, fail_on_brk = true)
      assert($0540 == $aa, "no wipe once complete")
    }
  }

  ; ----------------------------------------------------------------------
  ; move_sprites — position the 8 ball/X-logo sprites each frame from sine
  ; tables. For sprite x: X-lo = sine_x_lo[(zp_frame + sprite_xphase[x])],
  ; X-MSB bit from sine_x_hi[...], and Y from a per-band sine table chosen
  ; by sprite index: 0-2 -> sine_top, 3-5 -> sine_mid, 6-7 -> sine_bot,
  ; indexed by (zp_frame + sprite_yphase[x]). Writes $d000+2x / $d001+2x.
  ; Pure (deterministic on zp_frame + the phase/sine tables).
  ;   sprite_xphase = 0,32,64,96,128,160,192,224
  ;   sprite_yphase = 0,80,160,40,120,200,56,184
  ; zp_frame=$10 keeps every index (max 16+224=240) below 256 (no wrap),
  ; so assertions can index the tables directly. Self-consistent peekbyte.
  ; ----------------------------------------------------------------------
  suite("intro: move_sprites — sine-driven sprite positions") {
    symbols("/code/tests/sim6502/intro.sym")
    load("/code/tests/sim6502/intro.prg", strip_header = true)

    test("ms-x-from-sine", "sprite 0 X-lo comes from sine_x_lo[frame+xphase]") {
      $fe = $10          ; zp_frame = 16; sprite 0 xphase=0 -> index 16
      jsr([move_sprites], stop_on_rts = true, fail_on_brk = true)
      assert($d000 == peekbyte([sine_x_lo] + 16), "SPR0 X = sine_x_lo[16]")
    }

    test("ms-y-top-band", "sprites 0-2 take Y from sine_top") {
      $fe = $10          ; zp_frame = 16; sprite 0 yphase=0 -> index 16
      jsr([move_sprites], stop_on_rts = true, fail_on_brk = true)
      assert($d001 == peekbyte([sine_top] + 16), "SPR0 Y = sine_top[16]")
    }

    test("ms-y-mid-band", "sprites 3-5 take Y from sine_mid") {
      $fe = $10          ; sprite 3 yphase=40 -> index 16+40=56
      jsr([move_sprites], stop_on_rts = true, fail_on_brk = true)
      assert($d007 == peekbyte([sine_mid] + 56), "SPR3 Y = sine_mid[56]")
    }

    test("ms-y-bot-band", "sprites 6-7 take Y from sine_bot") {
      $fe = $10          ; sprite 6 yphase=56 -> index 16+56=72
      jsr([move_sprites], stop_on_rts = true, fail_on_brk = true)
      assert($d00d == peekbyte([sine_bot] + 72), "SPR6 Y = sine_bot[72]")
    }
  }
}
